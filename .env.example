# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Apify (scraping) ──────────────────────────────────────────────────────────
# Get from: https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Tavily (open-web search) ──────────────────────────────────────────────────
# Get from: https://app.tavily.com
TAVILY_KEY=tvly-XXXXXXXXXXXXXXXXXXXXXXXX

# ── Anthropic (Claude Haiku extraction) ───────────────────────────────────────
# Get from: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# ── Google Sheets ─────────────────────────────────────────────────────────────
# GOOGLE_SHEETS_CREDENTIALS: paste the full JSON content of your service account key
# (one line, JSON-encoded). See README step 2 for how to create this.
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"..."}

# The ID of your Google Sheet (the long string in the URL between /d/ and /edit)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ── Local dev flag ────────────────────────────────────────────────────────────
# Set to "true" to skip all API calls and use fixtures/sample_leads.json instead.
# Free to run, no credits consumed.
DRY_RUN=false
